// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: notebooks
// Document ID: {notebookId}
// Fields:
//   - title: string (required)
//   - createdAt: number (required)
//   - ownerId: string (required)
//   - lastModified: number (optional)
//
// Collection: notebooks/{notebookId}/sources
// Document ID: {sourceId}
// Fields:
//   - notebookId: string (required)
//   - name: string (required)
//   - content: string (required)
//   - type: string (optional)
//   - sourceType: string (required, enum: ['text', 'url', 'audio', 'video'])
//   - size: number (optional)
//   - authorId: string (required)
//   - createdAt: number (required)
//
// Collection: notebooks/{notebookId}/chatMessages
// Document ID: {messageId}
// Fields:
//   - notebookId: string (required)
//   - role: string (required, enum: ['user', 'assistant'])
//   - content: string (required)
//   - authorId: string (optional)
//   - createdAt: number (required)
//
// Collection: notebooks/{notebookId}/notes
// Document ID: {noteId}
// Fields:
//   - notebookId: string (required)
//   - content: string (required)
//   - authorId: string (required)
//   - createdAt: number (required)
//
// Collection: notebooks/{notebookId}/versions
// Document ID: {versionId}
// Fields:
//   - notebookId: string (required)
//   - content: string (required)
//   - createdAt: number (required)
//   - authorId: string (required)
//   - authorName: string (required)
//   - note: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isNotebookOwner(notebookId) {
      return isAuthenticated() && get(/databases/$(database)/documents/notebooks/$(notebookId)).data.ownerId == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidNotebook(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.createdAt is number &&
             data.ownerId == request.auth.uid;
    }

    function isValidSource(data) {
      return data.notebookId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.content is string && data.content.size() < 1000000 &&
             data.sourceType in ['text', 'url', 'audio', 'video'] &&
             data.authorId == request.auth.uid &&
             data.createdAt is number;
    }

    function isValidChatMessage(data) {
      return data.notebookId is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() < 100000 &&
             data.createdAt is number;
    }

    function isValidNote(data) {
      return data.notebookId is string &&
             data.content is string && data.content.size() < 100000 &&
             data.authorId == request.auth.uid &&
             data.createdAt is number;
    }

    function isValidVersion(data) {
      return data.notebookId is string &&
             data.content is string && data.content.size() < 1000000 &&
             data.createdAt is number &&
             data.authorId == request.auth.uid &&
             data.authorName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /notebooks/{notebookId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && isValidNotebook(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidNotebook(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);

      match /sources/{sourceId} {
        allow read: if isNotebookOwner(notebookId);
        allow create: if isNotebookOwner(notebookId) && isValidSource(request.resource.data);
        allow update: if isNotebookOwner(notebookId) && isValidSource(request.resource.data);
        allow delete: if isNotebookOwner(notebookId);
      }

      match /chatMessages/{messageId} {
        allow read: if isNotebookOwner(notebookId);
        allow create: if isNotebookOwner(notebookId) && isValidChatMessage(request.resource.data);
        allow update: if isNotebookOwner(notebookId) && isValidChatMessage(request.resource.data);
        allow delete: if isNotebookOwner(notebookId);
      }

      match /notes/{noteId} {
        allow read: if isNotebookOwner(notebookId);
        allow create: if isNotebookOwner(notebookId) && isValidNote(request.resource.data);
        allow update: if isNotebookOwner(notebookId) && isValidNote(request.resource.data);
        allow delete: if isNotebookOwner(notebookId);
      }

      match /versions/{versionId} {
        allow read: if isNotebookOwner(notebookId);
        allow create: if isNotebookOwner(notebookId) && isValidVersion(request.resource.data);
        allow update: if isNotebookOwner(notebookId) && isValidVersion(request.resource.data);
        allow delete: if isNotebookOwner(notebookId);
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
